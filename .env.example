# Minima / Mubit ---------------------------------------------------------------
# Your Mubit data-plane key (single-tenant). Used as the Bearer token to api.minima.sh,
# which routes recall/feedback to your Mubit memory instance (api.mubit.ai).
MUBIT_API_KEY=mbt_your_key_here
# Hosted Minima service the public SDK talks to.
MINIMA_BASE_URL=https://api.minima.sh

# Model providers ---------------------------------------------------------------
# Only the providers you want as live routing candidates are required. The dataset
# (replay) track needs none of these — it reproduces from a committed fixture.
ANTHROPIC_API_KEY=sk-ant-...
GEMINI_API_KEY=AIza...
OPENAI_API_KEY=sk-proj-...
